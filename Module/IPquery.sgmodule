[Panel]
IPquery = script-name=IPquery, style=info, update-interval=-1

[Script]
IPquery = type=generic, timeout=10, argument=group={{{组名称}}}&MaskIP={{{MaskIP}}}, script-path=IPquery_en.js, script-update-interval=-1
